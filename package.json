{
  "name": "arknights-vns",
  "version": "1.0.0",
  "description": "Random stuffs for akvns.org family of websites.",
  "homepage": "https://github.com/arknights-vns/akvns.org#readme",
  "bugs": {
    "url": "https://github.com/arknights-vns/akvns.org/issues"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Arknights Vietnam Station",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arknights-vns/akvns.org.git"
  },
  "scripts": {
    "prepare": "lefthook install --reset-hooks-path",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "dev": "pnpm run -r --if-present --parallel dev",
    "build": "pnpm run -r --if-present --parallel build",
    "start": "pnpm run -r --if-present --parallel start"
  },
  "devDependencies": {
    "lefthook": "^2.1.5",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.0"
  },
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "packageManager": "pnpm@10.28.2"
}
