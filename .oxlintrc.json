{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["nextjs", "typescript", "react", "react-perf", "jsx-a11y", "eslint", "import", "unicorn", "node", "promise"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "ignorePatterns": [
    "apps/dreamchasers/*",
    "apps/dreamchasers-db22c983/*",
    "packages/shadcn-ui/src/components/*",
    "packages/shadcn-ui/src/hooks/*",
    "packages/shadcn-ui/src/lib/*",
    "packages/database/generated/prisma/*"
  ],
  "overrides": [
    {
      "files": ["apps/www/src/components/opengraph/DefaultOpengraph.tsx"],
      "rules": {
        "nextjs/no-img-element": "off"
      }
    }
  ]
}
