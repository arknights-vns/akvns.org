{
  "name": "arknights-vns",
  "version": "1.0.0",
  "description": "Random stuffs for akvns.org family of websites.",
  "homepage": "https://github.com/arknights-vns/akvns.org#readme",
  "bugs": {
    "url": "https://github.com/arknights-vns/akvns.org/issues"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Arknights Vietnam Station",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arknights-vns/akvns.org.git"
  },
  "scripts": {
    "prepare": "node -e \"process.exit(process.env.CI ? 0 : 1)\" || husky",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "predev": "pnpm run -r  --parallel db:generate",
    "dev": "pnpm run -r  --parallel dev",
    "build": "pnpm run -r --parallel build",
    "start": "pnpm run -r  --parallel start"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0"
  },
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "packageManager": "pnpm@10.28.2"
}
